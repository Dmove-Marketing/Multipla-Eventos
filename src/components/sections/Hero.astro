---
// Hero.astro
---

<section class="hero-section">
  <!-- Imagem de Fundo do Hero -->
  <div class="hero-bg-wrapper">
    <!-- IMG: hero-bg -->
    <img 
      src="/images/hero-bg.jpg" 
      alt="Casamento dos Sonhos - Múltipla Eventos" 
      class="hero-bg" 
      fetchpriority="high"
      loading="eager"
      data-placeholder="hero-bg"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-container">
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="cursive-text">O dia que você imaginou.</span>
        <span class="bold-text">Vivido exatamente como sonhou.</span>
      </h1>
      
      <p class="hero-subtitle">
        A assessoria premiada pela Folha de São Paulo.<br />
        Para as noivas que não abrem mão do melhor.
      </p>

      <div class="hero-actions">
        <a href="#contato" class="btn btn-primary hero-btn">
          Quero conhecer
        </a>
      </div>
    </div>
  </div>
  
  <div class="hero-bottom-gradient"></div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 160px; /* Espaço para o cabeçalho absoluto */
    padding-bottom: var(--space-4xl);
    overflow: hidden;
    background-color: #0d0908;
    text-align: center;
  }

  /* Imagem de Fundo e Overlay */
  .hero-bg-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hero-bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(13, 9, 8, 0.7) 0%,
      rgba(13, 9, 8, 0.5) 50%,
      rgba(13, 9, 8, 0.9) 100%
    );
  }

  .hero-bottom-gradient {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 120px;
    background: linear-gradient(to top, #b98e75 0%, transparent 100%);
    z-index: 2;
    opacity: 0.8;
  }

  /* Conteúdo */
  .hero-container {
    position: relative;
    z-index: 5;
  }

  .hero-content {
    max-width: 860px;
    margin: 0 auto;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    margin-bottom: var(--space-xl);
    color: white;
  }

  .cursive-text {
    font-family: var(--font-cursive);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-primary-light);
    line-height: 1.1;
    letter-spacing: 0.01em;
    text-transform: none;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .bold-text {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto var(--space-3xl);
    text-shadow: 0 1px 5px rgba(0, 0, 0, 0.4);
    font-weight: 400;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
  }

  .hero-btn {
    padding: var(--space-md) var(--space-3xl);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: var(--radius-sm);
    box-shadow: 0 4px 20px rgba(185, 142, 117, 0.3);
    background-color: var(--color-primary);
    color: white;
    transition: transform var(--transition-fast), background-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .hero-btn:hover {
    transform: translateY(-2px);
    background-color: var(--color-primary-dark);
    box-shadow: 0 6px 24px rgba(185, 142, 117, 0.5);
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-top: 140px;
    }
    
    .hero-title {
      gap: var(--space-sm);
    }

    .hero-btn {
      width: 100%;
      max-width: 320px;
    }
  }
</style>
