---
// Footer.astro
---

<footer class="footer">
  <div class="container footer-container">
    <div class="footer-col copyright-col">
      <p class="copyright-text">Copyright &copy; 2025 - Multipla Eventos &ndash; Todos os direitos reservados</p>
    </div>
    
    <div class="footer-col logo-col">
      <div class="footer-logo-wrapper">
        <!-- IMG: footer-logo -->
        <img src="/images/logo.png" alt="Múltipla Eventos" class="footer-logo" data-placeholder="footer-logo" />
      </div>
    </div>
    
    <div class="footer-col credits-col">
      <p class="credits-label">Desenvolvido por:</p>
      <a href="http://dmove.com.br" target="_blank" rel="noopener noreferrer" class="credits-link">
        <!-- IMG: footer-logo-dmove -->
        <img src="/images/logo-dmove.png" alt="Dmove" class="credits-logo" data-placeholder="footer-logo-dmove" />
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #070404;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: var(--space-xl) 0;
    color: var(--text-secondary);
  }

  .footer-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-xl);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
  }

  .copyright-col {
    align-items: flex-start;
  }

  .copyright-text {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .logo-col {
    align-items: center;
  }

  .footer-logo-wrapper {
    max-width: 140px;
  }

  .footer-logo {
    width: 100%;
    height: auto;
    display: block;
  }

  .credits-col {
    align-items: flex-end;
    gap: var(--space-xs);
  }

  .credits-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .credits-link {
    display: inline-block;
    max-width: 100px;
    transition: transform var(--transition-fast);
  }

  .credits-link:hover {
    transform: translateY(-2px);
  }

  .credits-logo {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .footer {
      padding: var(--space-2xl) 0;
    }
    
    .footer-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-xl);
    }

    .copyright-col,
    .logo-col,
    .credits-col {
      align-items: center;
    }

    .copyright-text {
      font-size: 0.8rem;
    }

    .credits-col {
      flex-direction: row;
      justify-content: center;
      align-items: center;
      gap: var(--space-sm);
    }
  }
</style>
