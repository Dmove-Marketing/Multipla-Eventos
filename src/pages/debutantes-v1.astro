        <a class="gallery-item" href="#" data-lightbox-title="EHR06247">
          <Img src="EHR06247-scaled.avif" alt="Debutante EHR06247" width={800} height={533} class="gallery-img" />
          <div class="gallery-overlay"></div>
        </a>
        <a class="gallery-item" href="#" data-lightbox-title="018 - 1T5A0230">
          <Img src="018-1T5A0230-scaled.avif" alt="Debutante 018-1T5A0230" width={800} height={533} class="gallery-img" />
          <div class="gallery-overlay"></div>
        </a>
        <a class="gallery-item" href="#" data-lightbox-title="030 - IMGL7228">
          <Img src="030-IMGL7228-scaled.avif" alt="Debutante 030-IMGL7228" width={800} height={1200} class="gallery-img" />
          <div class="gallery-overlay"></div>
        </a>
        <a class="gallery-item" href="#" data-lightbox-title="034 - RNS_6868">
          <Img src="034-RNS_6868-scaled.avif" alt="Debutante 034-RNS_6868" width={800} height={533} class="gallery-img" />
          <div class="gallery-overlay"></div>
        </a>
        <a class="gallery-item" href="#" data-lightbox-title="1002_BAH08466_">
          <Img src="1002_BAH08466_-scaled.avif" alt="Debutante 1002_BAH08466_" width={800} height={533} class="gallery-img" />
          <div class="gallery-overlay"></div>
        </a>
        <a class="gallery-item" href="#" data-lightbox-title="044 - 1T5A3105">
          <Img src="044-1T5A3105-scaled.avif" alt="Debutante 044-1T5A3105" width={800} height={1200} class="gallery-img" />
          <div class="gallery-overlay"></div>
        </a>
        <a class="gallery-item" href="#" data-lightbox-title="Photo 23-02-24, 23 34 30">
          <Img src="Photo-23-02-24-23-34-30-scaled.avif" alt="Debutante Photo-23-02-24-23-34-30" width={800} height={533} class="gallery-img" />
          <div class="gallery-overlay"></div>
        </a>
        <a class="gallery-item" href="#" data-lightbox-title="_DG_7509">
          <Img src="DG_7509-scaled.avif" alt="Debutante DG_7509" width={800} height={533} class="gallery-img" />
          <div class="gallery-overlay"></div>
        </a>
        <a class="gallery-item" href="#" data-lightbox-title="1011_FLP09565_">
          <Img src="1011_FLP09565_-scaled.avif" alt="Debutante 1011_FLP09565_" width={800} height={533} class="gallery-img" />
          <div class="gallery-overlay"></div>
        </a>
        <a class="gallery-item" href="#" data-lightbox-title="1011_RNB02832_">
          <Img src="1011_RNB02832_-scaled.avif" alt="Debutante 1011_RNB02832_" width={800} height={533} class="gallery-img" />
          <div class="gallery-overlay"></div>
        </a>
        <a class="gallery-item" href="#" data-lightbox-title="Edilson Dias-20918">
          <Img src="Edilson-Dias-20918-scaled.avif" alt="Debutante Edilson-Dias-20918" width={800} height={1200} class="gallery-img" />
          <div class="gallery-overlay"></div>
        </a>
        <a class="gallery-item" href="#" data-lightbox-title="IMG_0316">
          <Img src="IMG_0316-scaled.avif" alt="Debutante IMG_0316" width={800} height={533} class="gallery-img" />
          <div class="gallery-overlay"></div>
        </a>
      </div>
    </section>
    <!-- 8. Contato / Formulário Section -->
    <section class="contact-section" id="contato">
      <div class="contact-overlay"></div>
      <div class="contact-container container">
        <div class="contact-content">
          <h2 class="contact-title">Chegou a sua vez de brilhar com a Múltipla!</h2>
          <p class="contact-subtitle">Preencha o formulário para receber nosso contato.</p>
        </div>
        <div class="contact-form-wrapper">
          <div class="contact-card card-vidro">
            <LeadForm
              formId="lead-form"
              formName="form_debutantes"
              project={config.project_slug}
              submitUrl={config.forms['lead-form'].webhooks[0]}
              redirectUrl={config.forms['lead-form'].redirect_on_success}
              submitText="Solicitar orçamento"
              honeypot
              fields={[
                { name: 'form_fields[servico]', payloadKey: 'Serviço', type: 'select', placeholder: '', required: true, options: [
                  { value: '', label: 'Objetivo de Contato' },
                  { value: 'Solicitar Orçamento', label: 'Solicitar Orçamento' },
                  { value: 'Fornecedor', label: 'Fornecedor' },
                  { value: 'Profissional buscando vaga', label: 'Profissional buscando vaga' }
                ] },
                { name: 'form_fields[nome]', payloadKey: 'Nome', type: 'text', placeholder: 'Nome completo', required: true },
                { name: 'form_fields[telefone]', payloadKey: 'WhatsApp', type: 'text', placeholder: 'WhatsApp', required: true },
                { name: 'form_fields[email]', payloadKey: 'E-mail', type: 'text', placeholder: 'E-mail', required: true },
                { name: 'form_fields[tipo]', payloadKey: 'Tipo de evento', type: 'select', placeholder: '', required: true, options: [
                  { value: '', label: 'Tipo de evento' },
                  { value: 'Aniversário', label: 'Aniversário' },
                  { value: 'Aniversário debutante', label: 'Aniversário debutante' },
                  { value: 'Confraternização social', label: 'Confraternização social' },
                  { value: 'Outros', label: 'Outros' }
                ] },
                { name: 'form_fields[data]', payloadKey: 'Data do evento', type: 'text', placeholder: 'Data do evento', required: true, id: 'lead-form-data', readonly: true },
                { name: 'form_fields[local_evento]', payloadKey: 'Local do evento', type: 'text', placeholder: 'Local do evento', required: true },
                { name: 'form_fields[convidados]', payloadKey: 'Convidados', type: 'number', placeholder: 'Quantidade de pessoas', required: true },
                { name: 'form_fields[mensagem]', payloadKey: 'Mensagem', type: 'textarea', placeholder: 'Informações adicionais (não obrigatório)', required: false }
              ]}
            />
          </div>
        </div>
      </div>
    </section>

    <!-- 9. Footer Section -->
    <footer class="footer-section">
      <div class="footer-container container">
        <div class="footer-copyright">
          <p>Copyright © 2026 - Múltipla Eventos – Todos os direitos reservados</p>
        </div>
        
        <div class="footer-logo-wrapper">
          <Img src="Multipla-principal_2400px.avif" alt="Múltipla Eventos" width={2400} height={1965} class="footer-logo" />
        </div>
        
        <div class="footer-credits">
          <span>Desenvolvido por:</span>
          <a href="http://dmove.com.br" target="_blank" rel="noopener noreferrer">
            <Img src="logo-dmove-1.avif" alt="DMove" width={2551} height={574} class="footer-dmove-logo" />
