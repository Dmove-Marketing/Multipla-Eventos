---
// Gerado a partir de: corporativo.html
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import Img from '../components/ui/Img.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import WhatsAppModal from '../components/layout/WhatsAppModal.astro';
import '../styles/corporativo.css';
---

<Base
  title="Corporativo - Multipla Eventos"
  ogImage="https://eventos.multiplaeventos.com.br/wp-content/uploads/2025/11/Multipla-principal_2400px.avif"
  canonical="https://eventos.multiplaeventos.com.br/corporativo/"
>
  <Fragment slot="head">
    <!-- Google Fonts: Bitter, Raleway, Montserrat -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bitter:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600;700&family=Raleway:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Flatpickr Library -->
    <link rel="stylesheet" href="https://npmcdn.com/flatpickr/dist/flatpickr.min.css" />
    <script is:inline src="https://npmcdn.com/flatpickr/dist/flatpickr.min.js"></script>
    <script is:inline src="https://npmcdn.com/flatpickr/dist/l10n/pt.js"></script>

    <!-- Icon Font CDNs -->
    <link rel="stylesheet" href="https://maxst.icons8.com/vue-static/landings/line-awesome/line-awesome/1.3.0/css/line-awesome.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/simple-line-icons/2.5.5/css/simple-line-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.lineicons.com/4.0/lineicons.css" />

    <!-- Swiper Library CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.css" />
    <script is:inline src="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.js"></script>
  </Fragment>

  <main class="corporativo-page">
    
    <!-- 1. Hero/Header Section -->
    <section class="hero-section">
      <div class="hero-overlay"></div>
      
      <div class="hero-container container">
        <div class="hero-logo-wrapper">
          <Img src="Multipla-principal_2400px.avif" alt="Múltipla Eventos Logo" class="hero-logo" priority />
        </div>
        
        <div class="hero-content">
          <h1 class="hero-title">Do planejamento à execução, cuidamos de cada fase do seu evento corporativo.</h1>
          <p class="hero-subtitle">A agência de assessoria Múltipla oferece soluções completas e personalizadas para a sua empresa.</p>
        </div>
        
        <div class="hero-cta-wrapper">
          <a class="hero-cta-btn" href="#contato">Quero mais informações</a>
        </div>
      </div>
    </section>

    <!-- 2. Intro/Sobre Section -->
    <section class="intro-section">
      <div class="intro-container container">
        <div class="intro-content">
          <h2 class="intro-title">Há 25 anos <br>tornando cada <br>evento inesquecível.</h2>
          <p class="intro-desc">
            Planejar e realizar um evento corporativo exige muito trabalho e organization, pois vai além de um único dia: trata-se de valorizar a marca e proporcionar uma experiência completa aos convidados. A Múltipla nasceu para tornar esse processo mais leve, com total dedicação à qualidade e ao profissionalismo.
          </p>
        </div>
      </div>
      
      <div class="intro-image-wrapper">
        <Img src="IMG_6964-2.avif" alt="Evento corporativo de sucesso planejado pela Múltipla" class="intro-img" />
      </div>
    </section>
      
    <!-- 3. Serviços Grid Section -->
    <section class="services-section">
      <div class="services-container container">
        <h2 class="services-title">Aqui, suas ideias são mais que bem-vindas</h2>
        <p class="services-desc">
          Oferecemos soluções personalizadas para diversos tipos de eventos corporativos, sempre alinhadas aos seus objetivos e à identidade da sua marca.
        </p>
        
        <div class="services-grid">
          <!-- Card 1 -->
          <div class="service-card">
            <div class="service-card-icon">
              <i class="la la-glass" aria-hidden="true"></i>
            </div>
            <h3 class="service-card-title">Confraternizações <br />e inaugurações.</h3>
          </div>
          
          <!-- Card 2 -->
          <div class="service-card">
            <div class="service-card-icon">
              <i class="las la-chalkboard-teacher" aria-hidden="true"></i>
            </div>
            <h3 class="service-card-title">Workshops, palestras <br>e treinamentos.</h3>
          </div>
          
          <!-- Card 3 -->
          <div class="service-card">
            <div class="service-card-icon">
              <i class="icons icon-rocket" aria-hidden="true"></i>
            </div>
            <h3 class="service-card-title">Lançamento de produtos e ativações de marca no pvd.</h3>
          </div>
          
          <!-- Card 4 -->
          <div class="service-card">
            <div class="service-card-icon">
              <i class="icons icon-trophy" aria-hidden="true"></i>
            </div>
            <h3 class="service-card-title">Eventos de incentivo e<br> premiações internas.</h3>
          </div>
          
          <!-- Card 5 -->
          <div class="service-card">
            <div class="service-card-icon">
              <i class="lni lni-coffee-cup" aria-hidden="true"></i>
            </div>
            <h3 class="service-card-title">Coffee Break e<br /> ações do Endo Marketing.</h3>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. Motivação Section -->
    <section class="motivation-section">
      <div class="motivation-container container">
        <h2 class="motivation-title">O impacto que nos motiva a fazer mais.</h2>
        <p class="motivation-desc">
          Nada nos motiva mais do que ver colaboradores engajados, clientes encantados e equipes inspiradas. Cada evento é uma oportunidade de fortalecer a cultura da empresa e gerar resultados concretos.
        </p>
      </div>
    </section>

    <!-- 5. Cases Section -->
    <section class="cases-section">
      <div class="cases-container container">
        <div class="cases-content">
          <h2 class="cases-title">Transformamos <br>projetos em verdadeiros <br>eventos de sucesso.</h2>
          <p class="cases-desc">
            Com a estratégia da Múltipla, seu evento acontece com organização, cuidado e segurança.
          </p>
        </div>
        <div class="cases-empty-col"></div>
      </div>
    </section>

    <!-- 6. Diferenciais Swiper Section -->
    <section class="differentials-section">
      <div class="differentials-container container">
        <h2 class="differentials-title">Por que contratar a Múltipla?</h2>
        
        <div class="swiper differentials-swiper">
          <div class="swiper-wrapper">
            <!-- Slide 1 -->
            <div class="swiper-slide">
              <div class="differential-card">
                <div class="differential-card-inner">
                  <h3 class="differential-card-title">Equipe de especialistas</h3>
                  <p class="differential-card-desc">
                    Contamos com um time completo onde escolhemos um para cuidar do seu evento conforme o perfil.
                  </p>
                  <a class="differential-card-btn" href="#contato">Saiba mais</a>
                </div>
              </div>
            </div>
            
            <!-- Slide 2 -->
            <div class="swiper-slide">
              <div class="differential-card">
                <div class="differential-card-inner">
                  <h3 class="differential-card-title">Credibilidade</h3>
                  <p class="differential-card-desc">
                    Garantia de um evento bem executado com uma marca de confiança.
                  </p>
                  <a class="differential-card-btn" href="#contato">Saiba mais</a>
                </div>
              </div>
            </div>
            
            <!-- Slide 3 -->
            <div class="swiper-slide">
              <div class="differential-card">
                <div class="differential-card-inner">
                  <h3 class="differential-card-title">Rede de Fornecedores</h3>
                  <p class="differential-card-desc">
                    Acesso aos melhores fornecedores do mercado.
                  </p>
                  <a class="differential-card-btn" href="#contato">Saiba mais</a>
                </div>
              </div>
            </div>
            
            <!-- Slide 4 -->
            <div class="swiper-slide">
              <div class="differential-card">
                <div class="differential-card-inner">
                  <h3 class="differential-card-title">Gestão de Riscos e Contingência</h3>
                  <p class="differential-card-desc">
                    Planos de contingência para garantir a resolução rápida de imprevistos.
                  </p>
                  <a class="differential-card-btn" href="#contato">Saiba mais</a>
                </div>
              </div>
            </div>
            
            <!-- Slide 5 -->
            <div class="swiper-slide">
              <div class="differential-card">
                <div class="differential-card-inner">
                  <h3 class="differential-card-title">Comunicação Clara</h3>
                  <p class="differential-card-desc">
                    Garantia de que todas as expectativas sejam atendidas, com processos bem comunicados.
                  </p>
                  <a class="differential-card-btn" href="#contato">Saiba mais</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 7. Depoimentos / Parceiros (Hidden in Production) -->
    <section class="partners-section hidden-section">
      <div class="partners-container container">
        <h2 class="partners-title">Uma vez com a Múltipla, sempre com a Múltipla.</h2>
        <p class="partners-desc">Veja as empresas que confiam em nossa assessoria.</p>
      </div>
    </section>

    <!-- 8. Galeria Oculta (Hidden in Production) -->
    <section class="gallery-section hidden-section">
      <div class="gallery-container container">
        <div class="gallery-grid">
          <div class="gallery-item">
            <Img src="delegates-networking-during-conference-lunch-break-2024-10-19-03-25-07-utc-scaled.avif" alt="Delegates Networking" width={2560} height={1707} />
          </div>
          <div class="gallery-item">
            <Img src="delegates-networking-during-coffee-break-at-confer-2024-10-21-20-15-13-utc-scaled.avif" alt="Coffee Break" width={2560} height={1707} />
          </div>
          <div class="gallery-item">
            <Img src="businesswoman-receiving-award-from-businessman-in-2025-04-03-21-24-51-utc-scaled.avif" alt="Award Ceremony" width={2560} height={1707} />
          </div>
          <div class="gallery-item">
            <Img src="business-team-office-in-new-years-party-2020-2025-03-25-19-17-23-utc-scaled.avif" alt="New Year Party" width={2560} height={1709} />
          </div>
          <div class="gallery-item">
            <Img src="businessmen-and-businesswomen-making-a-corporate-p-2025-04-01-02-35-16-utc-scaled.avif" alt="Corporate Party" width={2560} height={1707} />
          </div>
          <div class="gallery-item">
            <Img src="IMG_6965-1.avif" alt="IMG_6965" width={1600} height={1066} />
          </div>
        </div>
      </div>
    </section>

    <!-- 9. Contato Section -->
    <section class="contact-section" id="contato">
      <div class="contact-container container">
        <div class="contact-content">
          <h2 class="contact-title">Vamos começar a planejar seu evento?</h2>
          <p class="contact-desc">Preencha o formulário para receber nosso contato.</p>
        </div>
        
        <div class="contact-form-wrapper glass-card">
          <LeadForm
            formId="lead-form"
            formName="form_corporativo"
            project={config.project_slug}
            submitUrl={config.forms['lead-form'].webhooks[0]}
            redirectUrl={config.forms['lead-form'].redirect_on_success}
            submitText="Solicitar orçamento"
            honeypot
            fields={[
              { name: 'form_fields[servico]', payloadKey: 'Serviço', type: 'select', placeholder: '', required: true, options: [
                { value: '', label: 'Objetivo de Contato' },
                { value: 'Solicitar Orçamento', label: 'Solicitar Orçamento' },
                { value: 'Fornecedor', label: 'Fornecedor' },
                { value: 'Profissional buscando vaga', label: 'Profissional buscando vaga' }
              ] },
              { name: 'form_fields[nome]', payloadKey: 'Nome', type: 'text', placeholder: 'Nome completo', required: true },
              { name: 'form_fields[empresa]', payloadKey: 'Empresa', type: 'text', placeholder: 'Empresa', required: true },
              { name: 'form_fields[telefone]', payloadKey: 'WhatsApp', type: 'text', placeholder: 'WhatsApp', required: true },
              { name: 'form_fields[email]', payloadKey: 'E-mail', type: 'text', placeholder: 'E-mail', required: true },
              { name: 'form_fields[tipo]', payloadKey: 'Tipo de evento', type: 'select', placeholder: '', required: true, options: [
                { value: '', label: 'Tipo de evento' },
                { value: 'Confraternização corporativa', label: 'Confraternização corporativa' },
                { value: 'Corporativo', label: 'Corporativo' },
                { value: 'Feiras e Exposições', label: 'Feiras e Exposições' },
                { value: 'Masterclass e Palestras', label: 'Masterclass e Palestras' },
                { value: 'Mentorias e Treinamentos', label: 'Mentorias e Treinamentos' },
                { value: 'Offsite corporativo', label: 'Offsite corporativo' },
                { value: 'Reuniões de Networking', label: 'Reuniões de Networking' },
                { value: 'Shows e Festivais', label: 'Shows e Festivais' },
                { value: 'Workshops, Conferências e Seminários', label: 'Workshops, Conferências e Seminários' },
                { value: 'Outros', label: 'Outros' }
              ] },
              { name: 'form_fields[data]', payloadKey: 'Data do evento', type: 'text', placeholder: 'Data do evento', required: true },
              { name: 'form_fields[local_evento]', payloadKey: 'Local do evento', type: 'text', placeholder: 'Local do evento', required: true },
              { name: 'form_fields[convidados]', payloadKey: 'Convidados', type: 'number', placeholder: 'Quantidade de pessoas', required: true },
              { name: 'form_fields[mensagem]', payloadKey: 'Mensagem', type: 'textarea', placeholder: 'Informações adicionais (não obrigatório)', required: false }
            ]}
          />
        </div>
      </div>
    </section>

    <!-- 10. Footer Section -->
    <footer class="footer-section">
      <div class="footer-container container">
        <div class="footer-copyright">
          <p>Copyright © 2025 -Multipla Eventos – Todos os direitos reservados</p>
        </div>
        
        <div class="footer-logo-wrapper">
          <Img src="Multipla-principal_2400px.avif" alt="Múltipla Eventos" width={2400} height={1965} class="footer-logo" />
        </div>
        
        <div class="footer-credits">
          <span>Desenvolvido por:</span>
          <a href="http://dmove.com.br" target="_blank" rel="noopener noreferrer">
            <Img src="logo-dmove-1.avif" alt="DMove" width={2551} height={574} class="footer-dmove-logo" />
          </a>
        </div>
      </div>
    </footer>

  </main>

  <WhatsAppModal
    eventTypes={[
      { value: 'Confraternização corporativa', label: 'Confraternização corporativa' },
      { value: 'Corporativo', label: 'Corporativo' },
      { value: 'Feiras e Exposições', label: 'Feiras e Exposições' },
      { value: 'Masterclass e Palestras', label: 'Masterclass e Palestras' },
      { value: 'Mentorias e Treinamentos', label: 'Mentorias e Treinamentos' },
      { value: 'Offsite corporativo', label: 'Offsite corporativo' },
      { value: 'Reuniões de Networking', label: 'Reuniões de Networking' },
      { value: 'Shows e Festivais', label: 'Shows e Festivais' },
      { value: 'Workshops, Conferências e Seminários', label: 'Workshops, Conferências e Seminários' },
      { value: 'Outros', label: 'Outros' }
    ]}
  />
</Base>

<script>
  import '../scripts/corporativo.js';

  // Inicializa o carrossel Swiper Corporativo (Marquee linear super suave)
  const initSwiper = () => {
    if ((window as any).Swiper) {
      new (window as any).Swiper('.differentials-swiper', {
        slidesPerView: 4,
        spaceBetween: 20,
        loop: true,
        speed: 6000,
        autoplay: {
          delay: 0,
          disableOnInteraction: false,
        },
        breakpoints: {
          0: {
            slidesPerView: 1,
            spaceBetween: 10,
          },
          480: {
            slidesPerView: 2,
            spaceBetween: 15,
          },
          768: {
            slidesPerView: 2,
            spaceBetween: 15,
          },
          1024: {
            slidesPerView: 4,
            spaceBetween: 20,
          }
        }
      });
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSwiper);
  } else {
    initSwiper();
  }

  // Intercepta cliques nos botões "Saiba mais" do carrossel para rolar de forma suave até o formulário
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest('.differential-card-btn');
    if (btn) {
      e.preventDefault();
      const contactSection = document.getElementById('contato');
      if (contactSection) {
        contactSection.scrollIntoView({ behavior: 'smooth' });
      }
    }
  });

  // Máscara e validação do telefone
  function aplicarMascaraTelefone(valor: string) {
    valor = valor.replace(/\D/g, '');
    if (valor.length > 11) valor = valor.slice(0, 11);
    if (valor.length > 10) {
      return '(' + valor.slice(0, 2) + ') ' + valor.slice(2, 7) + '-' + valor.slice(7);
    } else if (valor.length > 6) {
      return '(' + valor.slice(0, 2) + ') ' + valor.slice(2, 6) + '-' + valor.slice(6);
    } else if (valor.length > 2) {
      return '(' + valor.slice(0, 2) + ') ' + valor.slice(2);
    }
    return valor;
  }

  function validarTelefone(valor: string) {
    const digitos = valor.replace(/\D/g, '');
    return digitos.length === 11 && digitos.charAt(2) === '9';
  }

  // Inicializar máscaras
  const inputTelefone = document.querySelector('input[name="form_fields[telefone]"]') as HTMLInputElement;
  if (inputTelefone) {
    inputTelefone.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      target.value = aplicarMascaraTelefone(target.value);
    });
  }

  // Validar no Envio
  const form = document.getElementById('form-lead-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      if (inputTelefone && !validarTelefone(inputTelefone.value)) {
        e.preventDefault();
        e.stopPropagation();
        
        let errorSpan = form.querySelector('.telefone-erro-msg') as HTMLElement;
        if (!errorSpan) {
          errorSpan = document.createElement('span');
          errorSpan.className = 'telefone-erro-msg';
          inputTelefone.parentNode?.appendChild(errorSpan);
        }
        errorSpan.textContent = 'Por favor, insira um celular válido (DDD + 9...).';
        inputTelefone.style.border = '1px solid #ff4a4a';
      } else {
        const errorSpan = form.querySelector('.telefone-erro-msg');
        if (errorSpan) errorSpan.remove();
        if (inputTelefone) inputTelefone.style.border = '';
      }
    });
  }

  // Inicializar Flatpickr nos campos locais de data
  const camposDeData = document.querySelectorAll('input[name="form_fields[data]"]');
  camposDeData.forEach((campo: any) => {
    if (!campo._flatpickr && (window as any).flatpickr) {
      (window as any).flatpickr(campo, {
        disableMobile: true,
        dateFormat: "d/m/Y",
        locale: "pt"
      });
    }
  });

  // Intercept click on elementor-action popup for WhatsApp modal (Popup ID 99)
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const a = target.closest('a');
    if (a && a.getAttribute('href')?.includes('eyJpZCI6Ijk5Iiw')) {
      e.preventDefault();
      
      const overlay = document.getElementById('wa-modal-overlay');
      if (overlay) {
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
        
        // Initialize flatpickr inside modal if flatpickr library is available
        const dateInput = document.getElementById('wa-data') as HTMLInputElement | null;
        if (dateInput && !dateInput._flatpickr && (window as any).flatpickr) {
          (window as any).flatpickr(dateInput, {
            disableMobile: true,
            dateFormat: "d/m/Y",
            locale: {
              weekdays: { shorthand: ["Dom", "Seg", "Ter", "Qua", "Qui", "Sex", "Sáb"], longhand: ["Domingo", "Segunda-feira", "Terça-feira", "Quarta-feira", "Quinta-feira", "Sexta-feira", "Sábado"] },
              months: { shorthand: ["Jan", "Fev", "Mar", "Abr", "Mai", "Jun", "Jul", "Ago", "Set", "Out", "Nov", "Dez"], longhand: ["Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho", "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"] },
              firstDayOfWeek: 1,
              rangeSeparator: " até ",
              ordinal: () => "º"
            }
          });
        }
      }
    }
  });
</script>
