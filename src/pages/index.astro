---
// Reconstrução Clean-Room da Página Principal de Casamentos
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import Img from '../components/ui/Img.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import WhatsAppModal from '../components/layout/WhatsAppModal.astro';
import '../styles/index.css';
---

<Base
  title="Casamentos - Multipla Eventos"
  ogImage="/images/og-default.jpg"
  canonical="https://eventos.multiplaeventos.com.br/casamentos/"
  bodyClass="casamentos-home-page"
>
  <Fragment slot="head">
    <!-- Wistia Player scripts loaded globally in head, matching production structure -->
    <script is:inline src="https://fast.wistia.com/player.js" async></script>
    <script is:inline src="https://fast.wistia.com/embed/b3jodnigjg.js" async type="module"></script>
    <!-- Google Fonts: Bitter e Fira Sans para a tipografia premium do projeto -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Fira+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Raleway:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Roboto:wght@400&display=swap" rel="stylesheet" />
    
    <!-- Flatpickr Library para seleção de datas -->
    <link rel="stylesheet" href="https://npmcdn.com/flatpickr/dist/flatpickr.min.css" />
    <script is:inline src="https://npmcdn.com/flatpickr/dist/flatpickr.min.js"></script>

    <!-- Swiper Library CDN para carrossel de depoimentos -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.css" />
    <script is:inline src="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.js"></script>
  </Fragment>

  <main>
    <!-- 1. Hero Section -->
    <section class="hero-section">
      <div class="hero-overlay"></div>
      <div class="hero-spacer"></div>
      <div class="hero-container">
        <a class="hero-cta-btn" href="#contato">Quero conhecer</a>
      </div>
    </section>

    <!-- 2. Intro Section (Rosé Gold) -->
    <section class="intro-section">
      <div class="container intro-grid">
        <div class="intro-content">
          <h2 class="section-title text-light">Há 25 anos transformando cada detalhe de seu casamento em uma obra-prima.</h2>
          <p class="section-desc text-light">
            Cada casamento começa por entender quem você é e qual o seu sonho. O espaço ideal, o clima que imaginou, os detalhes que fazem diferença para vocês dois. A partir daí, nossa equipe cuida de absolutamente tudo, dos primeiros planejamentos ao grande dia, para que você esteja presente em cada momento sem se preocupar com nada.
          </p>
        </div>
      </div>
      <div class="intro-image-wrapper">
        <Img src="Design-sem-nome-5.avif" alt="Casamento Múltipla Eventos" width={1920} height={1280} class="intro-img" priority />
      </div>
    </section>

    <!-- 3. Video Section -->
    <section class="video-section">
      <div class="container">
        <h2 class="section-title text-dark align-center">Seu casamento muito além do seu sonho.</h2>
        <div class="video-container">
          <wistia-player media-id="b3jodnigjg" aspect="1.7777777777777777"></wistia-player>
        </div>
      </div>
    </section>

    <!-- 4. Testimonials Section (Rosé Gold) -->
    <section class="testimonials-section">
      <div class="container">
        <h2 class="section-title text-light align-center">O que dizem os casais <br>que viveram a experiência Múltipla?</h2>
        
        <div class="testimonials-carousel-wrapper">
          <div class="swiper testimonials-swiper">
            <div class="swiper-wrapper">
              
              <!-- Slide 1 -->
              <div class="swiper-slide">
                <div class="testimonial-card">
                  <p class="testimonial-text">
                    "A Multipla/ Vinícius fez a assessoria do meu casamento. Ganhamos um amigo nessa organização. O Vinícius e a equipe fizeram com que tudo fosse perfeito, esteve presente desde as assinaturas do contrário até a organização final. Já estive com a Multipla em outros eventos e sempre impecável o trabalho! Super recomendo."
                  </p>
                  <span class="testimonial-author">Ana Flávia Torres Sampaio</span>
                </div>
              </div>

              <!-- Slide 2 -->
              <div class="swiper-slide">
                <div class="testimonial-card">
                  <p class="testimonial-text">
                    "Foi incrível ter a múltipla como assessoria do nosso casamento. A festa foi realizada em maio desse ano (2022), tudo planejado com antecedência e tranquilidade. Vinícius e Thâmisa que nos atenderam, foram muito profissionais, sempre nos orientando e ponderando todas situações. Recomendo de olhos fechados. Já estamos com saudades, já planejando a festa de bodas."
                  </p>
                  <span class="testimonial-author">Juliana Ornelas</span>
                </div>
              </div>

              <!-- Slide 3 -->
              <div class="swiper-slide">
                <div class="testimonial-card">
                  <p class="testimonial-text">
                    Não temos palavras suficientes para agradecer por tudo o que vocês fizeram por nós. O nosso casamento foi perfeito e grande parte disso se deve à dedicação, ao carinho e ao profissionalismo de vocês. Vocês cuidaram de tudo com tanto amor e atenção. A organização impecável e a sensibilidade com que conduziram cada momento fizeram toda a diferença. Obrigado por sonharem com a gente, por estarem presentes com tanto coração e por transformarem o nosso dia em algo ainda mais especial do que poderíamos imaginar. Levaremos vocês para sempre com muito carinho na nossa história. E que muitos outros casais tenham a sorte de contar com vocês nessa jornada tão linda.
                  </p>
                </div>
              </div>

              <!-- Slide 4 -->
              <div class="swiper-slide">
                <div class="testimonial-card">
                  <p class="testimonial-text">
                    Quero agradecer toda a equipe  da MultiplaEventos pelo dia de ontem, foi uma noite incrível, sempre estive segura desse evento, sempre tive em mente a certeza de que eu tinha profissionais extraordinários por trás desse evento extraordinária, vocês fizeram toda a diferença no nosso evento, foi tudo feito com todo o cuidado e dedicação por todos, @Daniela Multipla  você é uma profissional extraordinária , também quero pedir desculpas por qualquer coisa, os stress ou algo mais. Com certeza recomendaria essa empresa. Agradeça a toda sua equipe por nos @Daniela Multipla . 🙌🏻🙏🏻
                  </p>
                </div>
              </div>

              <!-- Slide 5 -->
              <div class="swiper-slide">
                <div class="testimonial-card">
                  <p class="testimonial-text">
                    Agora… um pouquinho depois do aniversário da Bia e já recuperados da festança 😄,  a gente segue revivendo cada detalhe com um misto de emoção e gratidão. E não tem como falar dessa festa sem falar de você, Lu. Você foi o fio condutor que fez tudo acontecer da melhor maneira possível. Coordenou cada frente: buffet, decoração, maquiadores, DJ, prestadores, fornecedores… td com uma leveza e firmeza que só quem ama o que faz consegue ter. A sintonia com a equipe da Noma, o cuidado com os detalhes, o olhar atento para o que importava de verdade... tudo refletiu o seu profissionalismo e dedicação. A festa foi um sucesso, e muito disso é mérito seu. Obrigada por ter nos acompanhado em cada etapa, por ter acolhido nossas ideias (e ansiedades 😅), e por ter feito com que tudo fluísse com tanta harmonia. Em nome da Bia, do Fernando e de toda a nossa família, o nosso carinho e um agradecimento enorme por ter feito parte desse momento inesquecível. 💛
                  </p>
                </div>
              </div>

              <!-- Slide 6 -->
              <div class="swiper-slide">
                <div class="testimonial-card">
                  <p class="testimonial-text">
                    Passando para agradecer a linda festa de sábado e por toda a sua dedicação em fazer tudo funcionar com tanto carinho como a Fernanda e nossa Família! Obrigada pela nossa parceira tão especial ao longo do tempo! Obrigada por me compreender no meu próprio processo de organizar as coisas e saiba que eu confiei mto em vc e na Múltipla! Equipe Múltipla obrigada pelo processo nesse último ano: da primeira reunião com a Jessica até toda a equipe que estava na festa que foram muito gentis e atenciosos conosco! Família Mascarenhas agradece demais por esse processo que foi lindo! 🥰
                  </p>
                </div>
              </div>

            </div>

            <!-- Custom Swiper Navigation Controls -->
            <div class="swiper-nav-prev" role="button" aria-label="Anterior">
              <svg aria-hidden="true" viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg"><path d="M646 125C629 125 613 133 604 142L308 442C296 454 292 471 292 487 292 504 296 521 308 533L604 854C617 867 629 875 646 875 663 875 679 871 692 858 704 846 713 829 713 812 713 796 708 779 692 767L438 487 692 225C700 217 708 204 708 187 708 171 704 154 692 142 675 129 663 125 646 125Z"></path></svg>
            </div>
            <div class="swiper-nav-next" role="button" aria-label="Próximo">
              <svg aria-hidden="true" viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg"><path d="M696 533C708 521 713 504 713 487 713 471 708 454 696 446L400 146C388 133 375 125 354 125 338 125 325 129 313 142 300 154 292 171 292 187 292 204 296 221 308 233L563 492 304 771C292 783 288 800 288 817 288 833 296 850 308 863 321 871 338 875 354 875 371 875 388 867 400 854L696 533Z"></path></svg>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 5. Styles Section -->
    <section class="styles-section">
      <div class="container">
        <h2 class="section-title text-dark align-center">Seu estilo. Nossa assinatura.</h2>
        <p class="section-subtitle text-dark align-center">Realize seu casamento sem limites, onde sua imaginação quiser.</p>
        
        <div class="styles-grid">
          
          <!-- Card 1 -->
          <div class="style-card style-destination">
            <div class="style-card-overlay"></div>
            <h3 class="style-card-title">Destination Wedding</h3>
          </div>

          <!-- Card 2 -->
          <div class="style-card style-praia">
            <div class="style-card-overlay"></div>
            <h3 class="style-card-title">Praia</h3>
          </div>

          <!-- Card 3 -->
          <div class="style-card style-igreja">
            <div class="style-card-overlay"></div>
            <h3 class="style-card-title">Igreja</h3>
          </div>

          <!-- Card 4 -->
          <div class="style-card style-city">
            <div class="style-card-overlay"></div>
            <h3 class="style-card-title">City Halls</h3>
          </div>

          <!-- Card 5 -->
          <div class="style-card style-castelos">
            <div class="style-card-overlay"></div>
            <h3 class="style-card-title">Castelos</h3>
          </div>

          <!-- Card 6 -->
          <div class="style-card style-fazendas">
            <div class="style-card-overlay"></div>
            <h3 class="style-card-title">Fazendas</h3>
          </div>

        </div>
      </div>
    </section>

    <!-- 6. Gallery Section (Rosé Gold) -->
    <section class="gallery-section">
      <div class="container">
        <h2 class="section-title text-light align-center">A celebração mais marcante de sua vida nas mãos da assessoria mais premiada de São Paulo.</h2>
        <p class="section-subtitle text-light align-center">Conheça os casais que escolheram a maior assessoria de eventos de São Paulo.</p>
        
        <div class="gallery-grid">
          
          <a class="gallery-item" href="#" data-title="Casamento | Foto 1">
            <Img src="0F2A8531-scaled.avif" alt="Casamento Múltipla Eventos 1" width={800} height={533} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 2">
            <Img src="2U8A8139-scaled.avif" alt="Casamento Múltipla Eventos 2" width={800} height={533} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 3">
            <Img src="cf30a024-97cc-46ae-a08f-4beee15ee637.avif" alt="Casamento Múltipla Eventos 3" width={800} height={533} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 4">
            <Img src="d81122c8-cc1f-405f-84f0-29cdc301dcab.avif" alt="Casamento Múltipla Eventos 4" width={800} height={533} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 5">
            <Img src="IMG_8496.avif" alt="Casamento Múltipla Eventos 5" width={800} height={533} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 6">
            <Img src="IMG_99452-scaled.avif" alt="Casamento Múltipla Eventos 6" width={800} height={1200} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 7">
            <Img src="01_Juliana-e-Marco-scaled.avif" alt="Casamento Múltipla Eventos 7" width={800} height={1200} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 8">
            <Img src="VR_previaJueRafa-146-2-scaled.avif" alt="Casamento Múltipla Eventos 8" width={800} height={533} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 9">
            <Img src="VR_previaJueRafa-136-2-scaled.avif" alt="Casamento Múltipla Eventos 9" width={800} height={533} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 10">
            <Img src="previa-fran-e-bruno22-150.avif" alt="Casamento Múltipla Eventos 10" width={800} height={533} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 11">
            <Img src="previa-fran-e-bruno22-113.avif" alt="Casamento Múltipla Eventos 11" width={800} height={533} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 12">
            <Img src="Espaco-Iate.avif" alt="Casamento Múltipla Eventos 12" width={800} height={800} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 13">
            <Img src="Marcos-Mesquita-Fotografia-15-scaled-e1762545725888.avif" alt="Casamento Múltipla Eventos 13" width={800} height={688} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 14">
            <Img src="0040.avif" alt="Casamento Múltipla Eventos 14" width={800} height={533} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 15">
            <Img src="IMG_3170-scaled.avif" alt="Casamento Múltipla Eventos 15" width={800} height={533} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

          <a class="gallery-item" href="#" data-title="Casamento | Foto 16">
            <Img src="77e68fb0-c64b-4cef-beab-d5e727f99383.avif" alt="Casamento Múltipla Eventos 16" width={800} height={533} class="gallery-img" />
            <div class="gallery-item-hover"></div>
          </a>

        </div>
      </div>
    </section>



    <!-- 8. Contact Section (#contato) -->
    <section class="contact-section" id="contato">
      <div class="contact-bg-overlay"></div>
      <div class="contact-inner">
        <div class="contact-text-col">
          <h2 class="section-title text-light">Uma celebração inesquecível começa agora.</h2>
          <p class="section-desc text-light">Preencha o formulário e nosso assessor entrará em contato para entender o seu evento.</p>
        </div>
        
        <div class="contact-form-col">
          <div class="card-vidro">
            <LeadForm
              formId="lead-form"
              formName="form_casamentos"
              project={config.project_slug}
              submitUrl={config.forms['lead-form'].webhooks[0]}
              redirectUrl={config.forms['lead-form'].redirect_on_success}
              submitText="Solicitar orçamento"
              honeypot
              fields={[
                { name: 'form_fields[servico]', payloadKey: 'Serviço', type: 'select', placeholder: '', required: true, options: [
                  { value: '', label: 'Objetivo de Contato' },
                  { value: 'Solicitar Orçamento', label: 'Solicitar Orçamento' },
                  { value: 'Fornecedor', label: 'Fornecedor' },
                  { value: 'Profissional buscando vaga', label: 'Profissional buscando vaga' }
                ] },
                { name: 'form_fields[nome]', payloadKey: 'Nome', type: 'text', placeholder: 'Nome completo', required: true },
                { name: 'form_fields[telefone]', payloadKey: 'WhatsApp', type: 'text', placeholder: 'WhatsApp', required: true },
                { name: 'form_fields[email]', payloadKey: 'E-mail', type: 'text', placeholder: 'E-mail', required: true },
                { name: 'form_fields[tipo]', payloadKey: 'Tipo de evento', type: 'select', placeholder: '', required: true, options: [
                  { value: '', label: 'Tipo de evento' },
                  { value: 'Bodas', label: 'Bodas' },
                  { value: 'Casamento', label: 'Casamento' },
                  { value: 'Outros', label: 'Outros' }
                ] },
                { name: 'form_fields[data]', payloadKey: 'Data do evento', id: 'lead-form-data', type: 'text', placeholder: 'Data do evento', required: true },
                { name: 'form_fields[local_evento]', payloadKey: 'Local do evento', type: 'text', placeholder: 'Espaço da Recepção', required: true },
                { name: 'form_fields[convidados]', payloadKey: 'Convidados', type: 'number', placeholder: 'Quantidade de pessoas', required: true },
                { name: 'form_fields[mensagem]', payloadKey: 'Mensagem', type: 'textarea', placeholder: 'Informações adicionais (não obrigatório)', required: false }
              ]}
            />
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- 9. Footer Section -->
  <footer class="footer-section">
    <div class="container footer-container">
      
      <div class="footer-copyright-side">
        <p class="footer-copyright-text">Copyright © 2025 - Multipla Eventos – Todos os direitos reservados</p>
      </div>

      <div class="footer-logo-main-side">
        <Img src="Multipla-principal_2400px.avif" alt="Múltipla Eventos" width={2400} height={1965} class="footer-logo-main" />
      </div>

      <div class="footer-credits-side">
        <span class="credits-label">Desenvolvido por:</span>
        <a href="http://dmove.com.br" target="_blank" rel="noopener noreferrer" class="credits-logo-link">
          <Img src="logo-dmove-1.avif" alt="DMove" width={2551} height={574} class="footer-logo-dmove" />
        </a>
      </div>

    </div>
  </footer>

  <!-- WhatsApp Floating Trigger (fixed bottom right) -->
  <div class="whatsapp-floating-trigger">
    <a href="#" class="whatsapp-trigger-btn" id="whatsapp-fixed-btn" aria-label="Conversar no WhatsApp">
      <svg xmlns="http://www.w3.org/2000/svg" width="2489" height="2500" viewBox="0 0 1219.547 1225.016">
        <path fill="#E0E0E0" d="M1041.858 178.02C927.206 63.289 774.753.07 612.325 0 277.617 0 5.232 272.298 5.098 606.991c-.039 106.986 27.915 211.42 81.048 303.476L0 1225.016l321.898-84.406c88.689 48.368 188.547 73.855 290.166 73.896h.258.003c334.654 0 607.08-272.346 607.222-607.023.056-162.208-63.052-314.724-177.689-429.463zm-429.533 933.963h-.197c-90.578-.048-179.402-24.366-256.878-70.339l-18.438-10.93-191.021 50.083 51-186.176-12.013-19.087c-50.525-80.336-77.198-173.175-77.16-268.504.111-278.186 226.507-504.503 504.898-504.503 134.812.056 261.519 52.604 356.814 147.965 95.289 95.36 147.728 222.128 147.688 356.948-.118 278.195-226.522 504.543-504.693 504.543z"></path>
        <linearGradient id="wa-grad" gradientUnits="userSpaceOnUse" x1="609.77" y1="1190.114" x2="609.77" y2="21.084">
          <stop offset="0" stop-color="#20b038"></stop>
          <stop offset="1" stop-color="#60d66a"></stop>
        </linearGradient>
        <path fill="url(#wa-grad)" d="M27.875 1190.114l82.211-300.18c-50.719-87.852-77.391-187.523-77.359-289.602.133-319.398 260.078-579.25 579.469-579.25 155.016.07 300.508 60.398 409.898 169.891 109.414 109.492 169.633 255.031 169.57 409.812-.133 319.406-260.094 579.281-579.445 579.281-.023 0 .016 0 0 0h-.258c-96.977-.031-192.266-24.375-276.898-70.5l-307.188 80.548z"></path>
        <path fill-rule="evenodd" clip-rule="evenodd" fill="#FFF" d="M462.273 349.294c-11.234-24.977-23.062-25.477-33.75-25.914-8.742-.375-18.75-.352-28.742-.352-10 0-26.25 3.758-39.992 18.766-13.75 15.008-52.5 51.289-52.5 125.078 0 73.797 53.75 145.102 61.242 155.117 7.5 10 103.758 166.266 256.203 226.383 126.695 49.961 152.477 40.023 179.977 37.523s88.734-36.273 101.234-71.297c12.5-35.016 12.5-65.031 8.75-71.305-3.75-6.25-13.75-10-28.75-17.5s-88.734-43.789-102.484-48.789-23.75-7.5-33.75 7.516c-10 15-38.727 48.773-47.477 58.773-8.75 10.023-17.5 11.273-32.5 3.773-15-7.523-63.305-23.344-120.609-74.438-44.586-39.75-74.688-88.844-83.438-103.859-8.75-15-.938-23.125 6.586-30.602 6.734-6.719 15-17.508 22.5-26.266 7.484-8.758 9.984-15.008 14.984-25.008 5-10.016 2.5-18.773-1.25-26.273s-32.898-81.67-46.234-111.326z"></path>
      </svg>
    </a>
  </div>

  <!-- Custom Premium Glassmorphism Lightbox Overlay -->
  <div id="custom-lightbox" class="custom-lightbox-overlay" aria-hidden="true">
    <div class="lightbox-backdrop"></div>
    <button class="lightbox-close" aria-label="Fechar galeria">&times;</button>
    <button class="lightbox-prev" aria-label="Imagem anterior">&#10094;</button>
    <div class="lightbox-content">
      <img id="lightbox-img" src="" alt="Visualização em tamanho cheio" />
    </div>
    <button class="lightbox-next" aria-label="Próxima imagem">&#10095;</button>
    <div class="lightbox-caption">
      <span id="lightbox-title"></span>
      <span id="lightbox-counter"></span>
    </div>
  </div>

  <!-- Modal do WhatsApp -->
  <WhatsAppModal
    eventTypes={[
      { value: 'Bodas', label: 'Bodas' },
      { value: 'Casamento', label: 'Casamento' },
      { value: 'Outros', label: 'Outros' }
    ]}
  />
</Base>

<script>
  import '../scripts/index.js';

  // Inicializador seguro do Swiper
  const runSwiper = () => {
    const SwiperLib = (window as any).Swiper;
    if (!SwiperLib) return;

    const testWrapper = document.querySelector('.testimonials-swiper');
    if (testWrapper) {
      testWrapper.classList.remove('swiper-initialized', 'swiper-pointer-events', 'swiper-backface-hidden');
      if ((testWrapper as any).swiper) {
        (testWrapper as any).swiper.destroy(true, true);
      }
      new SwiperLib(testWrapper, {
        slidesPerView: 1,
        spaceBetween: 30,
        loop: true,
        autoplay: {
          delay: 5000,
          disableOnInteraction: false,
        },
        speed: 600,
        navigation: {
          nextEl: '.testimonials-swiper-wrapper .swiper-nav-next, .testimonials-section .swiper-nav-next',
          prevEl: '.testimonials-swiper-wrapper .swiper-nav-prev, .testimonials-section .swiper-nav-prev',
        },
        breakpoints: {
          768: {
            slidesPerView: 1,
            spaceBetween: 50,
          }
        }
      });
    }
  };

  // Escuta clique no botão flutuante para abrir o modal de WhatsApp
  const initWhatsAppTrigger = () => {
    const waFixedBtn = document.getElementById('whatsapp-fixed-btn');
    waFixedBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      const overlay = document.getElementById('wa-modal-overlay');
      if (overlay) {
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
        
        // Inicializa Flatpickr interno do modal se necessário
        const dateInput = document.getElementById('wa-data') as HTMLInputElement | null;
        if (dateInput && !dateInput._flatpickr && (window as any).flatpickr) {
          (window as any).flatpickr(dateInput, {
            disableMobile: true,
            dateFormat: "d/m/Y",
            locale: {
              weekdays: { shorthand: ["Dom", "Seg", "Ter", "Qua", "Qui", "Sex", "Sáb"], longhand: ["Domingo", "Segunda-feira", "Terça-feira", "Quarta-feira", "Quinta-feira", "Sexta-feira", "Sábado"] },
              months: { shorthand: ["Jan", "Fev", "Mar", "Abr", "Mai", "Jun", "Jul", "Ago", "Set", "Out", "Nov", "Dez"], longhand: ["Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho", "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"] },
              firstDayOfWeek: 1,
              rangeSeparator: " até ",
              ordinal: () => "º"
            }
          });
        }
      }
    });
  };

  // Inicializador do Lightbox de Galeria
  const initLightbox = () => {
    const galleryContainer = document.querySelector('.gallery-grid');
    if (!galleryContainer) return;

    const items = Array.from(galleryContainer.querySelectorAll('a.gallery-item')) as HTMLAnchorElement[];
    const lightbox = document.getElementById('custom-lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const lightboxTitle = document.getElementById('lightbox-title');
    const lightboxCounter = document.getElementById('lightbox-counter');

    if (!lightbox || !lightboxImg || !lightboxTitle || !lightboxCounter) return;

    let currentIndex = 0;

    const updateLightbox = (index: number) => {
      currentIndex = index;
      const item = items[currentIndex];
      if (!item) return;

      const imgEl = item.querySelector('img');
      const optimizedSrc = imgEl ? imgEl.getAttribute('src') : item.getAttribute('href');
      const title = item.getAttribute('data-title') || `Foto ${currentIndex + 1}`;

      if (optimizedSrc && lightboxImg) {
        lightboxImg.src = optimizedSrc;
      }
      if (lightboxTitle) {
        lightboxTitle.textContent = title;
      }
      if (lightboxCounter) {
        lightboxCounter.textContent = `${currentIndex + 1} / ${items.length}`;
      }
    };

    const openLightbox = (index: number) => {
      updateLightbox(index);
      lightbox.classList.add('active');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      lightbox.classList.remove('active');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    const showNext = () => {
      const nextIndex = (currentIndex + 1) % items.length;
      updateLightbox(nextIndex);
    };

    const showPrev = () => {
      const prevIndex = (currentIndex - 1 + items.length) % items.length;
      updateLightbox(prevIndex);
    };

    // Associa eventos de clique nos itens da galeria
    items.forEach((item, index) => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        openLightbox(index);
      });
    });

    // Controles do Lightbox
    const closeBtn = lightbox.querySelector('.lightbox-close');
    const backdrop = lightbox.querySelector('.lightbox-backdrop');
    const prevBtn = lightbox.querySelector('.lightbox-prev');
    const nextBtn = lightbox.querySelector('.lightbox-next');

    closeBtn?.addEventListener('click', closeLightbox);
    backdrop?.addEventListener('click', closeLightbox);
    prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); showPrev(); });
    nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); showNext(); });

    // Suporte ao teclado
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('active')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') showNext();
      if (e.key === 'ArrowLeft') showPrev();
    });

    // Suporte ao gesto swipe no celular
    let startX = 0;
    let startY = 0;
    lightbox.addEventListener('touchstart', (e: TouchEvent) => {
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
    }, { passive: true });

    lightbox.addEventListener('touchend', (e: TouchEvent) => {
      const endX = e.changedTouches[0].clientX;
      const endY = e.changedTouches[0].clientY;
      const diffX = endX - startX;
      const diffY = endY - startY;

      if (Math.abs(diffX) > Math.abs(diffY)) {
        if (Math.abs(diffX) > 40) {
          if (diffX > 0) showPrev();
          else showNext();
        }
      } else {
        if (Math.abs(diffY) > 80) {
          closeLightbox();
        }
      }
    }, { passive: true });
  };

  // Inicializador do Flatpickr no formulário da página principal
  const initPageFlatpickr = () => {
    const dateInput = document.getElementById('lead-form-data') as HTMLInputElement | null;
    if (dateInput && !dateInput._flatpickr && (window as any).flatpickr) {
      (window as any).flatpickr(dateInput, {
        disableMobile: true,
        dateFormat: "d/m/Y",
        locale: {
          weekdays: { shorthand: ["Dom", "Seg", "Ter", "Qua", "Qui", "Sex", "Sáb"], longhand: ["Domingo", "Segunda-feira", "Terça-feira", "Quarta-feira", "Quinta-feira", "Sexta-feira", "Sábado"] },
          months: { shorthand: ["Jan", "Fev", "Mar", "Abr", "Mai", "Jun", "Jul", "Ago", "Set", "Out", "Nov", "Dez"], longhand: ["Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho", "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"] },
          firstDayOfWeek: 1,
          rangeSeparator: " até ",
          ordinal: () => "º"
        }
      });
    }
  };

  // Inicializador Geral
  const init = () => {
    runSwiper();
    initWhatsAppTrigger();
    initLightbox();
    initPageFlatpickr();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
