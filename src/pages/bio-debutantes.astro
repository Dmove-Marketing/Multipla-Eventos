---
// Múltipla Eventos - Bio Debutantes (Clean-Room)
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import Img from '../components/ui/Img.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import WhatsAppModal from '../components/layout/WhatsAppModal.astro';
import '../styles/bio-debutantes.css';
---

<Base
  title="BIO Debutantes - Multipla Eventos"
  ogImage="/images/og-default.jpg"
  canonical="https://eventos.multiplaeventos.com.br/bio-debutantes/"
>
  <Fragment slot="head">
    <!-- Google Fonts: Bitter e Raleway -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bitter:wght@400;500;600;700&family=Raleway:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Flatpickr Library -->
    <link rel="stylesheet" href="https://npmcdn.com/flatpickr/dist/flatpickr.min.css" />
    <script is:inline src="https://npmcdn.com/flatpickr/dist/flatpickr.min.js"></script>
    <script is:inline src="https://npmcdn.com/flatpickr/dist/l10n/pt.js"></script>
  </Fragment>

  <main class="bio-page">
    <div class="bio-container">
      <!-- Card do Topo com Foto de Fundo e Logo no Centro -->
      <header class="bio-card">
        <div class="bio-logo-wrapper">
          <Img src="Multipla-principal_2400px.avif" alt="Logo Múltipla Eventos" width={2400} height={1965} class="bio-logo" priority />
        </div>
      </header>

      <!-- Botão do WhatsApp (Fale Conosco) -->
      <a href="#whatsapp" id="fale-conosco-btn" class="bio-btn-whatsapp">
        <svg aria-hidden="true" class="whatsapp-icon" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg">
          <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"></path>
        </svg>
        <span>Fale conosco</span>
      </a>

      <!-- Container do Formulário de Orçamento -->
      <section class="bio-form-section">
        <h2 class="bio-form-title">Solicite um orçamento para o seu próximo evento!</h2>
        <LeadForm
          formId="lead-form"
          formName="form_bio_debutantes"
          project={config.project_slug}
          submitUrl={config.forms['lead-form'].webhooks[0]}
          redirectUrl={config.forms['lead-form'].redirect_on_success}
          submitText="Solicitar orçamento"
          honeypot
          fields={[
            { name: 'form_fields[servico]', payloadKey: 'Serviço', type: 'select', placeholder: '', required: true, options: [
              { value: '', label: 'Objetivo de Contato' },
              { value: 'Solicitar Orçamento', label: 'Solicitar Orçamento' },
              { value: 'Fornecedor', label: 'Fornecedor' },
              { value: 'Profissional buscando vaga', label: 'Profissional buscando vaga' }
            ] },
            { name: 'form_fields[nome]', payloadKey: 'Nome', type: 'text', placeholder: 'Nome completo', required: true },
            { name: 'form_fields[telefone]', payloadKey: 'WhatsApp', type: 'text', placeholder: 'WhatsApp', required: true },
            { name: 'form_fields[email]', payloadKey: 'E-mail', type: 'text', placeholder: 'E-mail', required: true },
            { name: 'form_fields[tipo]', payloadKey: 'Tipo de evento', type: 'select', placeholder: '', required: true, options: [
              { value: '', label: 'Tipo de evento' },
              { value: 'Debutante', label: 'Debutante' },
              { value: 'Aniversário', label: 'Aniversário' },
              { value: 'Outros', label: 'Outros' }
            ] },
            { name: 'form_fields[data]', payloadKey: 'Data do evento', type: 'text', placeholder: 'Data do evento', required: true },
            { name: 'form_fields[local_evento]', payloadKey: 'Local do evento', type: 'text', placeholder: 'Local do evento', required: true },
            { name: 'form_fields[convidados]', payloadKey: 'Convidados', type: 'number', placeholder: 'Quantidade de pessoas', required: true },
            { name: 'form_fields[mensagem]', payloadKey: 'Mensagem', type: 'textarea', placeholder: 'Informações adicionais (não obrigado)', required: false }
          ]}
        />
      </section>

    </div>

    <!-- Rodapé (Fora do container para largura total) -->
    <footer class="bio-footer">
      <p class="bio-copyright">Copyright © 2025 - Multipla Eventos – Todos os direitos reservados</p>
      <div class="bio-footer-logo-wrapper">
        <Img src="Multipla-principal_2400px.avif" alt="Múltipla Eventos" width={2400} height={1965} class="bio-footer-logo" />
      </div>
      <div class="bio-credits">
        <span>Desenvolvido por:</span>
        <a href="http://dmove.com.br" target="_blank" rel="noopener noreferrer">
          <Img src="logo-dmove-1.avif" alt="DMove" width={2551} height={574} class="bio-dmove-logo" />
        </a>
      </div>
    </footer>

    <!-- Modal WhatsApp Oculto e Ativo por Botão -->
    <WhatsAppModal
      eventTypes={[
        { value: 'Bodas', label: 'Bodas' },
        { value: 'Casamento', label: 'Casamento' },
        { value: 'Debutante', label: 'Debutante' },
        { value: 'Corporativo', label: 'Corporativo' },
        { value: 'Outros', label: 'Outros' }
      ]}
    />
  </main>
</Base>

<script>
  // Máscara e validação do telefone
  function aplicarMascaraTelefone(valor: string) {
    valor = valor.replace(/\D/g, '');
    if (valor.length > 11) valor = valor.slice(0, 11);
    if (valor.length > 10) {
      return '(' + valor.slice(0, 2) + ') ' + valor.slice(2, 7) + '-' + valor.slice(7);
    } else if (valor.length > 6) {
      return '(' + valor.slice(0, 2) + ') ' + valor.slice(2, 6) + '-' + valor.slice(6);
    } else if (valor.length > 2) {
      return '(' + valor.slice(0, 2) + ') ' + valor.slice(2);
    }
    return valor;
  }

  function validarTelefone(valor: string) {
    const digitos = valor.replace(/\D/g, '');
    return digitos.length === 11 && digitos.charAt(2) === '9';
  }

  // Inicializar máscaras
  const inputTelefone = document.querySelector('input[name="form_fields[telefone]"]') as HTMLInputElement;
  if (inputTelefone) {
    inputTelefone.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      target.value = aplicarMascaraTelefone(target.value);
    });
  }

  // Validar no Envio
  const form = document.getElementById('lead-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      if (inputTelefone && !validarTelefone(inputTelefone.value)) {
        e.preventDefault();
        e.stopPropagation();
        
        let errorSpan = form.querySelector('.telefone-erro-msg') as HTMLElement;
        if (!errorSpan) {
          errorSpan = document.createElement('span');
          errorSpan.className = 'telefone-erro-msg';
          inputTelefone.parentNode?.appendChild(errorSpan);
        }
        errorSpan.textContent = 'Por favor, insira um celular válido (DDD + 9...).';
        inputTelefone.style.border = '1px solid #ff4a4a';
      } else {
        const errorSpan = form.querySelector('.telefone-erro-msg');
        if (errorSpan) errorSpan.remove();
        if (inputTelefone) inputTelefone.style.border = '';
      }
    });
  }

  // Inicializar Flatpickr nos campos locais de data
  const camposDeData = document.querySelectorAll('input[name="form_fields[data]"]');
  camposDeData.forEach((campo: any) => {
    if (!campo._flatpickr && (window as any).flatpickr) {
      (window as any).flatpickr(campo, {
        disableMobile: true,
        dateFormat: "d/m/Y",
        locale: "pt"
      });
    }
  });

  // Interceptar cliques no botão "Fale Conosco" para o modal do WhatsApp
  const faleConoscoBtn = document.getElementById('fale-conosco-btn');
  faleConoscoBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    const overlay = document.getElementById('wa-modal-overlay');
    if (overlay) {
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
      
      const dateInput = document.getElementById('wa-data') as HTMLInputElement | null;
      if (dateInput && !dateInput._flatpickr && (window as any).flatpickr) {
        (window as any).flatpickr(dateInput, {
          disableMobile: true,
          dateFormat: "d/m/Y",
          locale: "pt"
        });
      }
    }
  });
</script>
